rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Users collection - allow users to read/write their own document + admin can read all
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin(); 
      allow write: if isAdmin(); 
    }
    
    // Courts collection - allow authenticated users to read
    match /courts/{courtId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Court Schedule collection
    match /courtSchedule/{scheduleId} {
      allow read: if request.auth != null; 
      allow write: if isAdmin(); 
    }
    
    // Reservations collection
    match /reservations/{reservationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (resource == null || 
         resource.data.userId == request.auth.uid || 
         resource.data.studentId == request.auth.uid ||
         isAdmin());
    }
    
    // Students collection - admin can read/write, students can read their own
    match /students/{studentId} {
      allow read: if isAuthenticated() && 
        (studentId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    // Attendance collection - Monthly aggregated docs
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Attendance Archive collection
    match /attendanceArchive/{archiveId} {
      allow read: if isAuthenticated() && 
        (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    // Dues collection - admin can read/write, students can read their own
    match /dues/{dueId} {
      allow read: if isAuthenticated() && 
        (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    // Groups collection
    match /groups/{groupId} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin(); 
    }
    
    // Settings collection
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Membership Types collection - all authenticated users can read, only admins can write
    match /membershipTypes/{typeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}