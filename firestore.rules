rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is boss (patron). Boss artık admin-eşi
    // tam yetkiye sahiptir: monitoring verisini okur VE admin'in yazabildiği
    // her koleksiyona yazabilir (kullanıcı kararı — eski salt-okunur tasarım
    // bilinçli olarak terk edildi).
    function isBoss() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'boss';
    }

    // Admin or boss — used to grant the monitoring read access boss needs.
    function isAdminOrBoss() {
      return isAdmin() || isBoss();
    }

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Users collection - allow users to read/write their own document + admin
    // can read/write all. Boss (patron) can READ all users (monitoring paneli
    // için öğrenci listesini sorgular) ama YAZAMAZ.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdminOrBoss();
      allow write: if isAdminOrBoss();
    }

    // Courts collection - allow authenticated users to read
    match /courts/{courtId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrBoss();
    }
    
    // Court Schedule collection
    match /courtSchedule/{scheduleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Reservations collection
    match /reservations/{reservationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (resource == null ||
         resource.data.userId == request.auth.uid ||
         resource.data.studentId == request.auth.uid ||
         isAdminOrBoss());
    }
    
    // Students collection - admin can read/write, students can read their own
    match /students/{studentId} {
      allow read: if isAuthenticated() &&
        (studentId == request.auth.uid || isAdminOrBoss());
      allow write: if isAdminOrBoss();
    }

    // Attendance collection - Monthly aggregated docs
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrBoss();
    }

    // Attendance Archive collection
    match /attendanceArchive/{archiveId} {
      allow read: if isAuthenticated() &&
        (resource.data.studentId == request.auth.uid || isAdminOrBoss());
      allow write: if isAdminOrBoss();
    }

    // Dues collection - admin/boss can read/write, students can read their own
    match /dues/{dueId} {
      allow read: if isAuthenticated() &&
        (resource.data.studentId == request.auth.uid || isAdminOrBoss());
      allow write: if isAdminOrBoss();
    }

    // Groups collection
    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrBoss();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrBoss();
    }

    // Membership Types collection - all authenticated users can read,
    // admin/boss can write.
    match /membershipTypes/{typeId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrBoss();
    }

    // Notifications collection - all authenticated users can read and write for the time being
    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    // Password resets (geçici şifre) collection — ARTIK KULLANILMIYOR.
    // Geçici şifre atama işi setTempPassword Cloud Function'ına (Admin SDK)
    // taşındı; öğrencinin gerçek Auth şifresi doğrudan güncelleniyor ve geçici
    // şifre Firestore'da düz metin olarak SAKLANMIYOR. Bu koleksiyona client
    // erişimi tamamen kapatıldı (geriye kalan eski dokümanlar için).
    match /passwordResets/{phone} {
      allow read, write: if false;
    }
  }
}